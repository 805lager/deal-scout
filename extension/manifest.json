{
  "manifest_version": 3,
  "name": "Deal Scout — AI Deal Scorer",
  "version": "0.42.5",
  "description": "AI deal scorer for Facebook Marketplace, Craigslist, eBay & OfferUp. Uses sold prices, market analysis & scam detection.",
  "permissions": [
    "activeTab",
    "storage",
    "webNavigation",
    "scripting"
  ],
  "host_permissions": [
    "https://www.facebook.com/marketplace/*",
    "https://www.craigslist.org/*",
    "https://*.craigslist.org/*",
    "https://www.ebay.com/*",
    "https://www.ebay.co.uk/*",
    "https://www.ebay.ca/*",
    "https://www.ebay.com.au/*",
    "https://www.ebay.de/*",
    "https://www.ebay.fr/*",
    "https://www.ebay.it/*",
    "https://www.ebay.es/*",
    "https://offerup.com/*",
    "https://www.offerup.com/*",
    "https://*.replit.app/*"
  ],
  "homepage_url": "https://deal-scout-805lager.replit.app/api/ds/privacy",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.facebook.com/marketplace/item/*",
        "https://www.facebook.com/marketplace/*/item/*",
        "https://www.facebook.com/marketplace/",
        "https://www.facebook.com/marketplace",
        "https://www.facebook.com/marketplace/search/*",
        "https://www.facebook.com/marketplace/category/*",
        "https://www.facebook.com/marketplace/*/search/*"
      ],
      "js": [
        "lib/purify.min.js",
        "content/fbm.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://*.craigslist.org/*"
      ],
      "js": [
        "lib/purify.min.js",
        "content/craigslist.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": [
        "https://www.ebay.com/itm/*",
        "https://www.ebay.com/p/*",
        "https://www.ebay.co.uk/itm/*",
        "https://www.ebay.co.uk/p/*",
        "https://www.ebay.ca/itm/*",
        "https://www.ebay.ca/p/*",
        "https://www.ebay.com.au/itm/*",
        "https://www.ebay.com.au/p/*",
        "https://www.ebay.de/itm/*",
        "https://www.ebay.de/p/*",
        "https://www.ebay.fr/itm/*",
        "https://www.ebay.fr/p/*",
        "https://www.ebay.it/itm/*",
        "https://www.ebay.it/p/*",
        "https://www.ebay.es/itm/*",
        "https://www.ebay.es/p/*"
      ],
      "js": [
        "lib/purify.min.js",
        "content/ebay.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://offerup.com/item/detail/*",
        "https://www.offerup.com/item/detail/*",
        "https://offerup.com/item/*",
        "https://www.offerup.com/item/*"
      ],
      "js": [
        "lib/purify.min.js",
        "content/offerup.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Deal Scout",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
