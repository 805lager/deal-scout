{
  "manifest_version": 3,
  "name": "Deal Scout — AI Deal Scorer",
  "version": "0.21.1",
  "description": "AI-powered deal scoring for Facebook Marketplace, Craigslist, and Amazon. Scores deals instantly using real market data.",

  "permissions": [
    "activeTab",
    "storage",
    "notifications",
    "clipboardWrite",
    "webNavigation",
    "scripting"
  ],

  "host_permissions": [
    "https://www.facebook.com/marketplace/*",
    "https://www.craigslist.org/*",
    "https://*.craigslist.org/*",
    "https://www.amazon.com/*"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": [
        "https://www.facebook.com/marketplace/item/*",
        "https://www.facebook.com/marketplace/*/item/*",
        "https://www.facebook.com/marketplace/",
        "https://www.facebook.com/marketplace",
        "https://www.facebook.com/marketplace/search/*",
        "https://www.facebook.com/marketplace/category/*",
        "https://www.facebook.com/marketplace/*/search/*"
      ],
      "js": ["content/fbm.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.craigslist.org/*/d/*/*",
        "https://*.craigslist.org/*/d/*/*"
      ],
      "js": ["content/craigslist.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.amazon.com/dp/*",
        "https://www.amazon.com/*/dp/*"
      ],
      "js": ["content/amazon.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Deal Scout",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
