modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Deal Scout API"

[[workflows.workflow]]
name = "Deal Scout API"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=8080 pnpm --filter @workspace/api-server run dev & cd artifacts/deal-scout-api && uvicorn main:app --host 0.0.0.0 --port 8000"
waitForPort = 8000

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"
packages = ["libxcrypt"]

[userenv]

[userenv.shared]
EBAY_APP_ID = "ShaunLag-DealScou-PRD-db58a57cb-b494510e"
EBAY_CAMPAIGN_ID = "5339144027"
EBAY_TRACKING_ID = "dealscout"
AMAZON_ASSOCIATE_TAG = "dealscout03f-20"
DS_API_KEY = "ds_live_098caae54340d797cb216856d0cffe50"
